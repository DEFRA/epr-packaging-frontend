@using FrontendSchemeRegistration.Application.Enums
@model CsocViewModel?

@if (Model is not null && Model.IsObligationDataSubmitted)
{
    var actorKey = Model switch
    {
        { IsComplianceScheme: true } => "compliance_scheme",
        { IsDirectProducer: true } => "direct_producer",
        _ => null
    };

    var statusKey = Model.ComplianceDeclarationStatus switch
    {
        ComplianceDeclarationStatus.Submitted or ComplianceDeclarationStatus.Accepted => "submitted",
        ComplianceDeclarationStatus.Cancelled => "cancelled",
        _ => "submit"
    };

    var regulator = Localizer[Model.NationId switch
    {
        (int)Nation.England => "regulator_england",
        (int)Nation.Scotland => "regulator_scotland",
        (int)Nation.Wales => "regulator_wales",
        (int)Nation.NorthernIreland => "regulator_northern_ireland",
        _ => "regulator"
    }];

    if (actorKey is not null)
    {
        <div class="govuk-card govuk-!-margin-bottom-6">
            <div class="govuk-card-body">
                <h2 class="govuk-heading-m">@Localizer[$"{statusKey}_heading_{actorKey}"]</h2>
                <p class="govuk-body">@Localizer[$"{statusKey}_paragraph_{actorKey}", regulator.Value, Model.ComplianceYear, Model.SubmissionDeadline]</p>
                @{
                    var showAction = Model.WasteObligationsBaseAddress is not null
                        && (statusKey == "submitted" || Model.IsApprovedUser);
                }
                @if (showAction)
                {
                    if (statusKey == "submitted")
                    {
                        <p class="govuk-body">
                            <a class="govuk-link govuk-link--no-visited-state" href="@Model.WasteObligationsBaseAddress">@Localizer[$"{statusKey}_button_{actorKey}"]</a>
                        </p>
                    }
                    else
                    {
                        <div class="govuk-button-group">
                            <a class="govuk-button govuk-button--secondary" href="@Model.WasteObligationsBaseAddress"
                               role="button" data-module="govuk-button">@Localizer[$"{statusKey}_button_{actorKey}"]</a>
                        </div>
                    }
                }
            </div>
        </div>
    }
}

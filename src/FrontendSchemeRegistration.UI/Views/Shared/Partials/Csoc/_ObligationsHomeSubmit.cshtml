@model CsocViewModel?

@if (Model is not null && Model.IsObligationDataSubmitted)
{
    var key = Model switch
    {
        { IsComplianceScheme: true } => "compliance_scheme",
        { IsDirectProducer: true } => "direct_producer",
        _ => null
    };

    if (key is not null)
    {
        <div class="govuk-card govuk-!-margin-bottom-6">
            <div class="govuk-card-body">
                <h2 class="govuk-heading-m">@Localizer[$"heading_{key}"]</h2>
                <p class="govuk-body">@string.Format(Localizer[$"paragraph_{key}"].Value, Model.ComplianceYear, Model.SubmissionDeadline)</p>
                @if (Model.IsApprovedUser && Model.UnderstandingObligationsEndpoint is not null)
                {
                    <div class="govuk-button-group">
                        <a class="govuk-button govuk-button--secondary" href="@Model.UnderstandingObligationsEndpoint"
                           role="button" data-module="govuk-button">@Localizer[$"button_{key}"]</a>
                    </div>
                }
            </div>
        </div>
    }
}